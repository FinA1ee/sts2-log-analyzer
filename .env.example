# Feishu Bot credentials
# Get these from https://open.feishu.cn → your app → Credentials
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here

# Where to send messages
# open_id: a user's open ID (starts with ou_)
# chat_id: a group chat ID (starts with oc_)
FEISHU_TARGET_ID=ou_xxxxxxxxxxxx
FEISHU_TARGET_TYPE=open_id

# Optional: Feishu Drive folder token to store docs in a specific folder
# Leave empty to create docs in root "My Drive"
FEISHU_FOLDER_TOKEN=

# Optional: Steam user ID (used to locate the .run save files)
# Default path: ~/Library/Application Support/SlayTheSpire2/steam/<STEAM_ID>/profile1/saves/history/
STEAM_ID=76561199098125055

# Optional: STS2 profile name (default: profile1)
PROFILE=profile1
